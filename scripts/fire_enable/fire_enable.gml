/// @description fire_enable()
function fire_enable() {
	//place in create event to enable particles for lighting an object on fire
	//by Ground Effect Games
	firesystem=0;
	fire1=0;
	fire2=0;
	fire3=0;
	onfire=0;
	burntime=0;
	smoke=0;//determines whether smoke will be generated. turn this off to improve framerate.
	char=0;



}
