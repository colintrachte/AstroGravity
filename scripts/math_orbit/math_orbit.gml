/// @description math_orbit(x,y,radius,angle)
/// @param x
/// @param y
/// @param radius
/// @param angle
function math_orbit(x, y, radius, angle) {
	//causes an object to orbit at given radius from a point.
	x=x+lengthdir_x(radius,angle)//multiply times any number for an ellipse
	y=y+lengthdir_y(radius,angle)//multiply times a different number for an ellipse



}
