//these variables handle timing
alarm0=2;
alarm1=4;
alarm2=.5;
sec=1;//this variable tracks delta time

flute=0;//don't start the flute right away, since that is the lead instrument
snare=0;//this drum is under the user's control
beat=0;//play a basic beat
bass=1;//play a simple bass tone
string1=0;//strings sound clip, part 1
string2=0;//strings, part 2
pattern=0;//synth pattern

//these settings can be used to disable an instrument type.
fluteenabled=0;
toneenabled=0;
stringenabled=1;
patternenabled=0;

